# ---------------------------------------------------------------------------
# UrbanPulse AI frontend configuration - EXAMPLE FILE
#
# These are now read at RUNTIME (via src/app/api/config/route.ts), not baked
# into the build. For local `next dev`, put them in `.env.local` as usual;
# once built into a Docker image / deployed to Cloud Run, you can change
# these by editing the container's environment variables and restarting -
# NO rebuild required. See src/lib/runtimeConfig.ts for the full explanation
# of why this changed from the old NEXT_PUBLIC_* build-time approach.
# ---------------------------------------------------------------------------

# FastAPI backend - must be reachable from the BROWSER (apiClient.ts fetches
# run client-side), so use the backend's public URL, not a Docker-internal
# hostname like http://backend:8080.
BACKEND_API_URL=http://localhost:8080

# Google OAuth Client ID (same value as backend's GOOGLE_OAUTH_CLIENT_ID)
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# Google Maps Browser API Key, used by src/components/MapPanel.tsx via the
# real Google Maps JavaScript API - restrict this key to your domain(s) in
# Google Cloud Console > Credentials.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Default Map Center
DEFAULT_LAT=28.716
DEFAULT_LNG=77.164
