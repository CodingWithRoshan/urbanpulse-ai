# ---------------------------------------------------------------------------
# UrbanPulse AI backend configuration (example — copy to .env and fill in)
# ---------------------------------------------------------------------------

ENVIRONMENT=development

# --- Gemini / Google GenAI ---------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-south1

# Enable only if your backend actually uses ADK
ADK_ENABLED=false

# --- Google Maps Platform -----------------------------------------------------
# One key with all needed APIs enabled (Weather, Air Quality, Distance Matrix,
# Time Zone, Maps JavaScript, etc.) works for everything below. Set per-service
# keys instead only if you want separately restricted keys per API.
GOOGLE_API_KEY=your-google-maps-platform-api-key
GOOGLE_MAPS_API_KEY=
GOOGLE_WEATHER_API_KEY=
GOOGLE_AQI_API_KEY=
GOOGLE_TIMEZONE_API_KEY=

# --- Weather (fallback if Google Weather API isn't enabled on your key) -------
OPENWEATHER_API_KEY=

# --- Firestore ---------------------------------------------------------------
FIRESTORE_PROJECT_ID=your-gcp-project-id
FIRESTORE_ENABLED=true

# --- Cloud Storage -----------------------------------------------------------
GCS_BUCKET_NAME=
GCS_ENABLED=false

# --- Auth / JWT --------------------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# Google OAuth Client ID
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# --- CORS --------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Default Location --------------------------------------------------------
DEFAULT_LAT=28.716
DEFAULT_LNG=77.164
