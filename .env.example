# ---------------------------------------------------------------------------
# Root-level environment file for `docker-compose.yml` ONLY.
#
# docker-compose.yml uses ${GOOGLE_OAUTH_CLIENT_ID} and ${GOOGLE_MAPS_API_KEY}
# as frontend build-args. docker-compose automatically loads a file named
# `.env` from the same directory as docker-compose.yml to fill in those
# ${...} references - this file didn't exist before, so both variables
# silently resolved to empty strings and the frontend image was built with
# a broken Google Sign-In button and no maps key, with only a barely-visible
# "variable is not set" warning from docker-compose to show for it.
#
# Copy this to `.env` (same directory as docker-compose.yml) and fill in
# real values before running `docker compose up --build`.
#
# The backend's OWN variables (Gemini key, JWT secret, etc.) still come from
# backend/.env via docker-compose.yml's `env_file: ./backend/.env` - this
# root file only feeds the two frontend build-args docker-compose needs
# before the frontend container even starts.
# ---------------------------------------------------------------------------

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_MAPS_API_KEY=
